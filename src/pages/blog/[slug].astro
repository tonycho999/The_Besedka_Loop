---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// 이 함수는 그대로 둡니다.
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// --- 이 아래 부분을 수정합니다 ---

// 1. Astro.props의 타입을 명확하게 정의합니다.
type Props = {
  entry: CollectionEntry<'blog'>;
}
const { entry } = Astro.props;

// 2. entry.render()는 그대로 사용합니다.
const { Content } = await entry.render();
---

{/* HTML 부분은 수정할 필요 없이 그대로 둡니다. */}
<Layout title={entry.data.title} description={entry.data.description}>
	<article class="prose lg:prose-xl mx-auto">
		<!-- 포스트 헤더 -->
		<header class="mb-8 text-center">
			<span class="text-blue-600 font-semibold tracking-wider uppercase">{entry.data.category}</span>
			<h1 class="text-4xl font-extrabold mt-2 mb-4 leading-tight">{entry.data.title}</h1>
			<p class="text-gray-500">
				Published on {entry.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
			</p>
		</header>

		<!-- 메인 이미지 (있을 경우) -->
		{entry.data.image && (
			<img src={entry.data.image} alt={entry.data.title} class="w-full h-[400px] object-cover rounded-lg shadow-md mb-10" />
		)}

		<!-- 마크다운 본문 렌더링 영역 -->
		<div class="markdown-content leading-relaxed text-gray-800">
			<Content />
		</div>

		<!-- 태그 영역 -->
		<div class="mt-10 pt-6 border-t border-gray-200">
			<h3 class="text-lg font-semibold mb-3">Tags:</h3>
			<div class="flex flex-wrap gap-2">
				{entry.data.tags.map((tag) => (
					<span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-full text-sm">#{tag}</span>
				))}
			</div>
		</div>
	</article>
</Layout>

{/* 스타일 부분도 그대로 둡니다. */}
<style is:global>
	.markdown-content h2 { @apply text-3xl font-bold mt-10 mb-4 text-gray-900; }
	.markdown-content h3 { @apply text-2xl font-bold mt-8 mb-3 text-gray-800; }
	.markdown-content p { @apply mb-6; }
	.markdown-content a { @apply text-blue-600 hover:underline; }
	.markdown-content ul { @apply list-disc list-inside mb-6; }
	.markdown-content strong { @apply font-bold text-gray-900; }
	
	.markdown-content .affiliate-button {
		@apply inline-block bg-orange-500 text-white font-bold py-3 px-6 rounded-lg my-6 hover:bg-orange-600 transition-colors shadow-sm;
		text-decoration: none !important;
	}
</style>
