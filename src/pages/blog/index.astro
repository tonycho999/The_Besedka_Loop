---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<Layout
  title="All Blog Posts"
  description="Browse all articles from Ultimate Philippines Hub."
>
  <h1 class="text-4xl font-extrabold mb-8">All Posts</h1>

  {/* 향후 이 곳에 검색, 태그 필터 기능이 추가될 예정 */}

  <section class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {posts.map((post) => (
      <article class="bg-white rounded-lg shadow overflow-hidden transition-transform hover:-translate-y-1">
        {post.data.image && (
          <img src={post.data.image} alt={post.data.title} class="w-full h-48 object-cover" />
        )}
        <div class="p-6">
          <span class="text-sm font-semibold text-blue-600 uppercase">{post.data.category}</span>
          <h2 class="text-2xl font-bold mt-2 mb-3">
            <a href={`/blog/${post.slug}`} class="hover:text-blue-600 transition-colors">
              {post.data.title}
            </a>
          </h2>
          <p class="text-gray-600 mb-4">{post.data.description}</p>
          <div class="text-sm text-gray-500">
            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          .
          </div>
        </div>
      </a
    ))}
  </section>

  {/* 향후 이 곳에 페이지네이션(1, 2, 3...) 기능이 추가될 예정 */}
</Layout>
